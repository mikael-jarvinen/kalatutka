# Both Dockerfiles share this build context. Each only COPYs:
#   web      → src/, deploy/nginx.conf
#   refresh  → scripts/, deploy/refresh-entrypoint.sh
# Everything else is dead weight in the image and can be excluded.

# Version control
.git/
.gitignore
.gitattributes

# Docker / compose (no need inside the image)
Dockerfile*
docker-compose*.yml
.dockerignore

# Project docs and meta — not needed at runtime
README.md
CLAUDE.md
docs/

# Node tooling — not used here, but defensive
node_modules/
npm-debug.log*
yarn-debug.log*
package-lock.json

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Local-only outputs
/tmp/
*.log

# Environment files (never bake secrets into images)
.env
.env.*
