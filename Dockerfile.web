# Web image: nginx serving the static frontend.
#
# Static HTML/CSS/JS is baked in at build time. The data.js + snapshot.json
# come from a shared volume populated by the refresh container, mounted at
# /usr/share/nginx/html/data.

FROM nginx:1.27-alpine

COPY src/ /usr/share/nginx/html/
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

# The data/ directory is the volume mount target. Pre-create it owned by
# uid 1000 so that if this container initialises the named volume first, the
# permissions match the non-root refresh container (also uid 1000) that's
# the sole writer.
RUN mkdir -p /usr/share/nginx/html/data && chown 1000:1000 /usr/share/nginx/html/data

EXPOSE 80
