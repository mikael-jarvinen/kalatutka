# Web image: nginx serving the static frontend.
#
# Static HTML/CSS/JS is baked in at build time. The data.js + snapshot.json
# come from a shared volume populated by the refresh container, mounted at
# /usr/share/nginx/html/data.

FROM nginx:1.27-alpine

COPY src/ /usr/share/nginx/html/
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

# The data/ directory is the volume mount target. Make sure it exists in the
# image so nginx doesn't 404 before the refresh container has run.
RUN mkdir -p /usr/share/nginx/html/data

EXPOSE 80
